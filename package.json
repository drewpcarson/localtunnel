{
  "name": "localtunnel",
  "version": "1.0.4",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "test": "echo \"No tests yet\"",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win nsis",
    "dist:win:publish": "electron-builder --win nsis --x64 --publish always"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "LAN clipboard and file transfer desktop app",
  "build": {
    "appId": "com.drewpcarson.localtunnel",
    "productName": "LocalTunnel Portal",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "mac": {
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "drewpcarson",
        "repo": "localtunnel",
        "releaseType": "release"
      }
    ]
  },
  "dependencies": {
    "cors": "^2.8.6",
    "electron-updater": "^6.3.9",
    "express": "^5.2.1",
    "jszip": "^3.10.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "electron": "^40.7.0",
    "electron-builder": "^24.13.3"
  }
}
